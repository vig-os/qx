{
  "format_version": 1,
  "collections": [
    {
      "name": "parts",
      "id": { "scheme": "nano14", "default": true, "mintable": true, "prefix_length": 8 },
      "lifecycle": {
        "statuses": ["unbound", "bound", "void"],
        "transitions": { "unbound": ["bound", "void"], "bound": ["void"], "void": [] },
        "initial": "unbound"
      },
      "open_properties": true,
      "render": { "label_fields": ["id", "type"] },
      "fields": [
        { "key": "type", "type": "string", "label": "Type", "editable": true,
          "required_to_enter": "bound", "maxLength": 100,
          "render": { "widget": "text", "order": 1 } },
        { "key": "description", "type": "string", "label": "Description", "editable": true,
          "meaningful_from": "bound", "maxLength": 500,
          "render": { "widget": "textarea", "order": 2 } },
        { "key": "manufacturer", "type": "reference", "label": "Manufacturer", "editable": true,
          "meaningful_from": "bound", "collection": "companies", "display": "label",
          "on_unknown": "reject", "render": { "widget": "picker", "order": 3 } },
        { "key": "part_number", "type": "string", "label": "Part number", "editable": true,
          "meaningful_from": "bound", "maxLength": 100,
          "render": { "widget": "text", "order": 4 } },
        { "key": "datasheet", "type": "attachment", "label": "Datasheet", "editable": true,
          "constraint": "pdf|png", "render": { "widget": "file", "order": 5 } }
      ]
    },
    {
      "name": "companies",
      "id": { "scheme": "nano14", "default": false, "mintable": true },
      "lifecycle": {
        "statuses": ["active", "archived"],
        "transitions": { "active": ["archived"], "archived": ["active"] },
        "initial": "active"
      },
      "open_properties": true,
      "render": { "label_fields": ["label"] },
      "fields": [
        { "key": "label", "type": "string", "label": "Name", "editable": true,
          "required": true, "maxLength": 200, "render": { "widget": "text", "order": 1 } },
        { "key": "role", "type": "enum", "label": "Role", "editable": true, "required": true,
          "values": ["manufacturer", "distributor", "both"], "closed": true,
          "render": { "widget": "dropdown", "order": 2 } },
        { "key": "qualification", "type": "enum", "label": "Qualification", "editable": true,
          "values": ["candidate", "qualified", "suspended"], "closed": true,
          "render": { "widget": "dropdown", "order": 3 } },
        { "key": "website", "type": "string", "label": "Website", "editable": true,
          "maxLength": 300, "pattern": "^https?://", "render": { "widget": "text", "order": 4 } },
        { "key": "primary_contact", "type": "reference", "label": "Primary contact",
          "editable": true, "collection": "contacts", "display": "name", "on_unknown": "warn",
          "render": { "widget": "picker", "order": 5 } },
        { "key": "quality_agreement", "type": "attachment", "label": "Quality agreement",
          "editable": true, "constraint": "pdf", "render": { "widget": "file", "order": 6 } },
        { "key": "certification", "type": "attachment", "label": "ISO 9001 / 13485 certificate",
          "editable": true, "constraint": "pdf", "render": { "widget": "file", "order": 7 } }
      ]
    },
    {
      "name": "contacts",
      "id": { "scheme": "nano14", "default": false, "mintable": true },
      "render": { "label_fields": ["name"] },
      "fields": [
        { "key": "name", "type": "string", "label": "Name", "editable": true,
          "required": true, "maxLength": 200, "render": { "widget": "text", "order": 1 } },
        { "key": "company", "type": "reference", "label": "Company", "editable": true,
          "required": true, "collection": "companies", "display": "label", "on_unknown": "reject",
          "render": { "widget": "picker", "order": 2 } },
        { "key": "email", "type": "string", "label": "Email", "editable": true,
          "maxLength": 200, "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$",
          "render": { "widget": "text", "order": 3 } },
        { "key": "phone", "type": "string", "label": "Phone", "editable": true,
          "maxLength": 40, "render": { "widget": "text", "order": 4 } },
        { "key": "function", "type": "string", "label": "Function / role", "editable": true,
          "maxLength": 100, "render": { "widget": "text", "order": 5 } }
      ]
    }
  ]
}
