# anchor.yml — the ADR-037 anchor ledger for a deployed qx data repo
# data repo. Seeded by tools/bootstrap-data-repo.sh.
#
# Every push to __BRANCH__ publishes a small immutable release pinning
# {head_sha, prev_anchor_sha, stream digest} — the freeze line. A
# nightly cron publishes a heartbeat when no push anchored that day, so
# ledger silence is unambiguous (a gap means a problem, never a quiet
# day). Anchors publish ONLY after the gate passes: each anchor attests
# a *verified* state; on failure the job opens an issue and fails loud.
#
# Load-bearing prerequisite (ADR-037 §5): the repo setting "immutable
# releases" must be enabled — `pr verify --anchors` checks it; a ledger
# on mutable releases is not a ledger.
name: anchor
on:
  push:
    branches: ["__BRANCH__"]
  schedule:
    - cron: "17 2 * * *" # nightly heartbeat (UTC)
  workflow_dispatch:

permissions:
  contents: write # create anchor releases
  issues: write   # loud failure (ADR-037 §3: gap + issue = the alarm)

concurrency:
  group: anchor-ledger # serialized writer — checkpoint/ledger ordering
  cancel-in-progress: false

jobs:
  anchor:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0 # ancestry rule needs full history

      # Gate artifact: prefer the vendored copy (ADR-038 §1), fall back
      # to the pinned release fetch. Both verify sha256 before exec.
      - name: gate binary
        run: |
          if [ -f .qx/gate/pr.zst ] && [ -f .qx/gate/pr.sha256 ]; then
            zstd -d -o pr .qx/gate/pr.zst
            sha256sum -c .qx/gate/pr.sha256
          else
            curl -fsSL -o pr \
              "https://github.com/__CODE_REPO__/releases/download/__PR_VERSION__/qx-x86_64-unknown-linux-gnu"
            echo "__PR_SHA256__  pr" | sha256sum -c -
          fi
          chmod +x pr

      # Anchor only a verified state (ADR-037 §3). `pr check` is the
      # current full-repo validation; upgrades to `pr verify` when that
      # subcommand lands (obligations: pr-verify-offline).
      - name: verify repo state
        run: ./pr check --path .

      - name: previous anchor + ancestry rule
        id: prev
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          prev_tag=$(gh release list --repo "${GITHUB_REPOSITORY}" \
            --limit 100 --json tagName -q '[.[].tagName | select(startswith("anchor-"))][0] // empty')
          prev_sha=""
          if [ -n "$prev_tag" ]; then
            gh release download "$prev_tag" --repo "${GITHUB_REPOSITORY}" \
              --pattern "anchor-manifest.json" --output prev-manifest.json
            prev_sha=$(jq -r .head_sha prev-manifest.json)
            # The tamper signal (ADR-037 §3): every anchored head must
            # be an ancestor of the next. Non-fast-forward = rewrite.
            if ! git merge-base --is-ancestor "$prev_sha" HEAD; then
              echo "::error::ancestry rule violated — ${prev_sha} (${prev_tag}) is not an ancestor of HEAD. Possible history rewrite."
              exit 1
            fi
          fi
          echo "tag=${prev_tag}" >> "$GITHUB_OUTPUT"
          echo "sha=${prev_sha}" >> "$GITHUB_OUTPUT"

      - name: decide + publish
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          head_sha=$(git rev-parse HEAD)
          prev_sha='${{ steps.prev.outputs.sha }}'
          prev_tag='${{ steps.prev.outputs.tag }}'
          reason="push"
          if [ "${GITHUB_EVENT_NAME}" = "schedule" ] || [ "${GITHUB_EVENT_NAME}" = "workflow_dispatch" ]; then
            if [ "$head_sha" = "$prev_sha" ]; then
              # Heartbeat at most once per day: skip if today already anchored.
              prev_day=$(echo "$prev_tag" | sed -n 's/^anchor-\([0-9]\{8\}\).*/\1/p')
              today=$(date -u +%Y%m%d)
              if [ "$prev_day" = "$today" ]; then
                echo "already anchored today (${prev_tag}) — skipping"
                exit 0
              fi
              reason="heartbeat"
            else
              reason="catchup" # head moved but no push-anchor covered it
            fi
          fi
          # Stream digest: jsonl (ADR-035) or the csv predecessor.
          stream=""
          for f in audit_log.jsonl audit_log.csv; do
            [ -f "$f" ] && stream="$f" && break
          done
          if [ -n "$stream" ]; then
            digest=$(sha256sum "$stream" | awk '{print $1}')
            lines=$(wc -l < "$stream" | tr -d ' ')
          else
            digest=""; lines=0
          fi
          tag="anchor-$(date -u +%Y%m%d-%H%M%S)"
          jq -n \
            --arg head_sha "$head_sha" \
            --arg prev_anchor_sha "$prev_sha" \
            --arg prev_anchor_tag "$prev_tag" \
            --arg stream_file "$stream" \
            --arg stream_digest "$digest" \
            --argjson stream_lines "$lines" \
            --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            --arg reason "$reason" \
            --arg run "${GITHUB_SERVER_URL}/${GITHUB_REPOSITORY}/actions/runs/${GITHUB_RUN_ID}" \
            '{head_sha:$head_sha, prev_anchor_sha:$prev_anchor_sha, prev_anchor_tag:$prev_anchor_tag, stream_file:$stream_file, stream_digest:$stream_digest, stream_lines:$stream_lines, ts:$ts, reason:$reason, run:$run}' \
            > anchor-manifest.json
          gh release create "$tag" anchor-manifest.json \
            --repo "${GITHUB_REPOSITORY}" \
            --target "$head_sha" \
            --title "$tag (${reason})" \
            --notes "ADR-037 anchor: \`${head_sha}\` (${reason}). Verify with \`pr verify --anchors\`."

      - name: loud failure
        if: failure()
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          gh issue create --repo "${GITHUB_REPOSITORY}" \
            --title "anchor failed: $(date -u +%Y-%m-%d) — ledger gap" \
            --body "The anchor workflow failed on ${GITHUB_SHA}. Per ADR-037 §3 a ledger gap plus this issue IS the alarm: investigate before merging further changes. Run: ${GITHUB_SERVER_URL}/${GITHUB_REPOSITORY}/actions/runs/${GITHUB_RUN_ID}" \
            || true
