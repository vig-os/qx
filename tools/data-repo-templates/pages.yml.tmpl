# Deploy this data repo's part-registry FE to GitHub Pages.
# Rendered by `tools/bootstrap-data-repo.sh`; placeholders:
#   __CODE_REPO__   — source repo for the bundle (e.g. MorePET/part-registry)
#   __DATA_REPO__   — this repo (e.g. exo-pet/exopet-registry-sandbox)
#   __PAGES_BASE__  — Vite base path (e.g. /exopet-registry-sandbox/)
name: Deploy registry FE to GitHub Pages

on:
  push:
    branches: [main]
  workflow_dispatch:
    inputs:
      bundle_tag:
        description: "Code-repo release tag to deploy (default: latest)"
        required: false
        default: latest

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false

env:
  CODE_REPO: __CODE_REPO__
  DATA_REPO_SLUG: __DATA_REPO__
  BUNDLE_TAG: ${{ inputs.bundle_tag || 'latest' }}

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Download release bundle
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail
          if [ "${BUNDLE_TAG}" = "latest" ]; then
            gh release download --repo "${CODE_REPO}" \
              --pattern "frontend-bundle-*.tar.gz" \
              --pattern "sha256sums-*.txt"
          else
            gh release download "${BUNDLE_TAG}" --repo "${CODE_REPO}" \
              --pattern "frontend-bundle-*.tar.gz" \
              --pattern "sha256sums-*.txt"
          fi

      - name: Verify SHA-256
        run: sha256sum --check sha256sums-*.txt

      - name: Extract bundle
        run: tar xzf frontend-bundle-*.tar.gz

      - name: Record provenance
        run: cat BUNDLE_METADATA.json

      - uses: actions/setup-node@v4
        with:
          node-version: "22"
          cache: "npm"
          cache-dependency-path: web/package-lock.json

      - name: npm ci
        working-directory: web
        run: npm ci

      - name: npm run build
        working-directory: web
        env:
          VITE_DATA_REPO: ${{ env.DATA_REPO_SLUG }}
          VITE_BASE: __PAGES_BASE__
        run: npm run build

      - uses: actions/configure-pages@v5
      - uses: actions/upload-pages-artifact@v3
        with:
          path: web/dist

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - id: deployment
        uses: actions/deploy-pages@v4
