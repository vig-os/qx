# Generated label artifacts (regenerable from registry + label.py).
# Per-ID SVGs are high-volume and noisy in diffs; sheet outputs under
# sheets/ stay tracked so they can be shared and printed straight from
# the repo without rerunning tools/sheet.py.
labels/

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/

# uv
uv.lock

# macOS
.DS_Store

# Rust
target/
**/*.rs.bk
